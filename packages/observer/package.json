{
  "name": "@republique/observer",
  "version": "0.1.0",
  "description": "CLI pour surveiller les votes republique.vote en temps réel et vérifier l'intégrité de la chaîne",
  "type": "module",
  "bin": {
    "republique-observer": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@republique/core": "workspace:^",
    "commander": "^14.0.3",
    "eventsource": "^3.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  }
}
